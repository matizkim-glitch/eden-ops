# Eden Recyclers BOS runtime configuration
# Copy to .env for local tooling, and mirror these values in the hosting provider.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Canonical public origin used by Supabase password reset links.
SUPABASE_REDIRECT_URL=https://your-production-domain.example

# Keep false in staging/production unless actively debugging a deployment.
EDEN_DEBUG=false
